{
  "name": "@forthebots/bazaar-sdk",
  "version": "0.1.1",
  "description": "TypeScript SDK for the noui.bot Agent Bazaar — billing, metering, and tool proxy for MCP servers",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test dist/test.js"
  },
  "keywords": [
    "mcp",
    "bazaar",
    "agent",
    "billing",
    "metering",
    "noui",
    "ai-agent",
    "tool-proxy"
  ],
  "author": "Tombstone Dash LLC <info@tombstonedash.com>",
  "license": "MIT",
  "homepage": "https://noui.bot/docs/bazaar",
  "repository": {
    "type": "git",
    "url": "https://github.com/TombStoneDash/noui-bot",
    "directory": "packages/bazaar-sdk"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  }
}
